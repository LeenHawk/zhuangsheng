{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "庄生",
  "version": "0.0.1",
  "identifier": "dev.zhuangsheng.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm --filter @zhuangsheng/desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm --filter @zhuangsheng/desktop build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "庄生", "width": 1200, "height": 800, "minWidth": 320, "minHeight": 560 }],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: blob: data:; connect-src ipc: http://ipc.localhost" }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
